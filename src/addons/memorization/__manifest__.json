{
  "name": "memorization",
  "version": "1.0.0",
  "summary": "Quran Memorization Tracking",
  "description": "Comprehensive memorization tracking with spaced repetition algorithm, achievements, and gamification",
  "author": "Quran Platform Team",
  "license": "LGPL-3",
  "category": "Quran",
  "depends": ["base", "quran"],
  "data": [
    "security/memorization_groups.json",
    "security/memorization_acl.json",
    "security/memorization_rules.json",
    "data/achievements.json",
    "views/memorization_plan_views.json",
    "views/memorization_progress_views.json",
    "views/revision_schedule_views.json",
    "views/achievement_views.json",
    "views/memorization_menu_views.json"
  ],
  "demo": [
    "data/demo_memorization.json"
  ],
  "workflows": [
    "models/memorization_plan.py"
  ],
  "automation": [
    "automation/revision_reminder.json",
    "automation/daily_reminder.json",
    "automation/achievement_check.json"
  ],
  "cron": [
    {
      "name": "Daily Revision Reminder",
      "model": "quran.memorization.plan",
      "function": "send_daily_reminders",
      "interval": "days",
      "interval_number": 1
    },
    {
      "name": "Process Spaced Repetition",
      "model": "quran.memorization.progress",
      "function": "process_spaced_repetition",
      "interval": "hours",
      "interval_number": 6
    }
  ],
  "assets": {
    "web.assets_frontend": [
      "memorization/static/src/css/memorization.css",
      "memorization/static/src/js/memorization_dashboard.js"
    ]
  },
  "installable": true,
  "application": true,
  "autoInstall": false
}
