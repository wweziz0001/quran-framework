{
  "name": "memorization",
  "version": "17.0.1.0.0",
  "summary": "Quran Memorization Module - Spaced Repetition & Progress Tracking",
  "description": "Comprehensive memorization module with SM-2 algorithm, spaced repetition, progress tracking, achievements, and daily revision schedules. Following Odoo Framework methodology.",
  "author": "Quran Platform Team",
  "license": "LGPL-3",
  "category": "Quran",
  "website": "https://github.com/wweziz0001/quran-framework",
  "depends": ["quran"],
  
  "data": [
    "security/memorization_security.json",
    "security/memorization_acl.json",
    "data/achievement_types.ts",
    "views/memorization_views.json"
  ],
  
  "demo": [
    "demo/index.ts"
  ],
  
  "assets": {
    "web.assets_frontend": [
      "memorization/static/css/memorization.css",
      "memorization/static/js/memorization.js"
    ]
  },
  
  "i18n": [
    "i18n/ar.json",
    "i18n/en.json"
  ],
  
  "controllers": [
    "controllers/memorization_controller.ts"
  ],
  
  "models": [
    "models/memorization_plan.ts"
  ],
  
  "features": [
    "spaced_repetition",
    "sm2_algorithm",
    "progress_tracking",
    "streak_tracking",
    "achievements",
    "daily_revision",
    "statistics",
    "calendar_view"
  ],
  
  "installable": true,
  "application": true,
  "autoInstall": false
}
