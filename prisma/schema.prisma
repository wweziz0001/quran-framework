// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== Base Models ====================

model User {
  id                Int       @id @default(autoincrement())
  email             String    @unique
  passwordHash      String
  name              String?
  avatarUrl         String?
  
  // Groups
  groups            UserGroup[] @relation("UserToGroup")
  
  // Quran relations
  bookmarks         QuranBookmark[]
  readingHistory    QuranReadingHistory[]
  memorizationPlans QuranMemorizationPlan[]
  achievements      QuranAchievement[]
  userSettings      QuranUserSettings?
  
  // New relations
  sessions          UserSession[]
  notifications     Notification[]
  collections       Collection[]
  analytics         Analytics[]
  
  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastLoginAt       DateTime?
  isActive          Boolean   @default(true)
  deletedAt         DateTime?
  
  @@index([email])
  @@index([isActive])
  @@index([deletedAt])
}

model UserGroup {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  category    String?
  impliedIds  String   // JSON string of group IDs
  
  users       User[]   @relation("UserToGroup")
  
  createdAt   DateTime @default(now())
  
  @@index([name])
}

// ==================== Quran Models ====================

model QuranSurah {
  id                  Int     @id @default(autoincrement())
  number              Int     @unique
  nameArabic          String
  nameEnglish         String
  nameTransliteration String?
  slug                String? @unique
  
  // Classification
  revelationType      String  @default("makki") // makki, madani
  revelationOrder     Int?
  
  // Content
  totalAyahs          Int
  
  // Location
  pageNumberStart     Int?
  juzNumberStart      Int?
  
  // Statistics
  wordCount           Int     @default(0)
  letterCount         Int     @default(0)
  
  // Description
  description         String?
  themes              String?
  
  // Relations
  ayahs               QuranAyah[]
  recitations         QuranRecitation[]
  tafsirEntries       QuranTafsirEntry[]
  
  // Timestamps
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  active              Boolean  @default(true)
  
  @@index([revelationType])
  @@index([number])
  @@index([slug])
}

model QuranAyah {
  id               Int               @id @default(autoincrement())
  surahId          Int
  ayahNumber       Int
  ayahNumberGlobal Int               @unique
  
  // Text variations
  textArabic       String
  textUthmani      String?
  textIndopak      String?
  textClean        String?           // Without diacritics
  
  // Location
  pageNumber       Int?
  juzNumber        Int?
  hizbNumber       Int?
  rubNumber        Int?
  quarterNumber    Int?
  manzilNumber     Int?
  
  // Special markers
  sajdah           Boolean           @default(false)
  sajdahType       String?           // obligatory, recommended
  sajdahNumber     Int?
  
  // Statistics
  wordCount        Int?
  letterCount      Int?
  
  // Relations
  surah            QuranSurah        @relation(fields: [surahId], references: [id], onDelete: Cascade)
  bookmarks        QuranBookmark[]
  readingHistory   QuranReadingHistory[]
  recitationAyahs  QuranRecitationAyah[]
  tafsirEntries    QuranTafsirEntry[]
  translationEntries QuranTranslationEntry[]
  memorizationProgress QuranMemorizationProgress[]
  
  // New relations
  searchIndex      SearchIndex?
  wordAnalyses     WordAnalysis[]
  audioFiles       AudioFile[]
  collectionItems  CollectionItem[]
  analytics        Analytics[]
  
  // Timestamps
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  active           Boolean           @default(true)
  deletedAt        DateTime?
  
  @@unique([surahId, ayahNumber])
  @@index([juzNumber])
  @@index([pageNumber])
  @@index([ayahNumberGlobal])
  @@index([deletedAt])
}

// ==================== Translation ====================

model QuranTranslationSource {
  id               String  @id
  name             String
  language         String
  languageCode     String  @unique
  author           String?
  description      String?
  isDefault        Boolean @default(false)
  isActive         Boolean @default(true)
  
  entries          QuranTranslationEntry[]
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  @@index([isDefault])
  @@index([languageCode])
}

model QuranTranslationEntry {
  id          String                @id @default(cuid())
  ayahId      Int
  sourceId    String
  text        String
  footnotes   String?
  
  ayah        QuranAyah             @relation(fields: [ayahId], references: [id], onDelete: Cascade)
  source      QuranTranslationSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  
  @@unique([ayahId, sourceId])
  @@index([sourceId])
}

// ==================== Tafsir ====================

model QuranTafsirSource {
  id            String             @id
  nameArabic    String
  nameEnglish   String
  slug          String             @unique
  authorArabic  String?
  authorEnglish String?
  description   String?
  language      String             @default("ar")
  isDefault     Boolean            @default(false)
  isActive      Boolean            @default(true)
  
  entries       QuranTafsirEntry[]
  
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  
  @@index([isDefault])
  @@index([language])
}

model QuranTafsirEntry {
  id               String            @id @default(cuid())
  surahId          Int
  ayahId           Int
  sourceId         String
  textArabic       String?
  textTranslation  String?
  htmlContent      String?
  wordExplanations String?          // JSON
  
  surah            QuranSurah        @relation(fields: [surahId], references: [id], onDelete: Cascade)
  ayah             QuranAyah         @relation(fields: [ayahId], references: [id], onDelete: Cascade)
  source           QuranTafsirSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  
  @@unique([ayahId, sourceId])
  @@index([sourceId])
  @@index([surahId])
}

// ==================== Audio ====================

model QuranReciter {
  id             String           @id @default(cuid())
  nameArabic     String
  nameEnglish    String
  slug           String           @unique
  bio            String?
  imageUrl       String?
  country        String?
  deathYear      Int?
  apiIdentifier  String?          @unique
  
  hasHighQuality Boolean          @default(false)
  hasGapless     Boolean          @default(false)
  totalDownloads Int              @default(0)
  popularity     Int              @default(0)
  isActive       Boolean          @default(true)
  
  recitations    QuranRecitation[]
  
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?
  
  @@index([popularity])
  @@index([isActive])
  @@index([deletedAt])
}

model QuranRecitation {
  id              String              @id @default(cuid())
  surahId         Int
  reciterId       String
  style           String
  bitrate         Int                 @default(128)
  format          String              @default("mp3")
  
  audioUrl        String
  audioUrlHd      String?
  timingDataUrl   String?
  
  fileSize        Int?
  durationSeconds Int?
  downloadCount   Int                 @default(0)
  
  isActive        Boolean             @default(true)
  
  surah           QuranSurah          @relation(fields: [surahId], references: [id], onDelete: Cascade)
  reciter         QuranReciter        @relation(fields: [reciterId], references: [id], onDelete: Cascade)
  ayahTimings     QuranRecitationAyah[]
  audioFiles      AudioFile[]
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?
  
  @@unique([surahId, reciterId, style])
  @@index([surahId])
  @@index([reciterId])
  @@index([deletedAt])
}

model QuranRecitationAyah {
  id           String         @id @default(cuid())
  recitationId String
  ayahId       Int
  startTimeMs  Int
  endTimeMs    Int
  audioUrl     String?
  
  recitation   QuranRecitation @relation(fields: [recitationId], references: [id], onDelete: Cascade)
  ayah         QuranAyah       @relation(fields: [ayahId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime       @default(now())
  
  @@unique([recitationId, ayahId])
  @@index([ayahId])
}

// ==================== User Data ====================

model QuranBookmark {
  id        String      @id @default(cuid())
  userId    Int
  ayahId    Int
  type      String      @default("BOOKMARK")
  note      String?
  color     String?
  
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  ayah      QuranAyah   @relation(fields: [ayahId], references: [id], onDelete: Cascade)
  
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  
  @@unique([userId, ayahId, type])
  @@index([userId])
  @@index([ayahId])
}

model QuranReadingHistory {
  id              Int      @id @default(autoincrement())
  userId          Int
  ayahId          Int
  lastReadAt      DateTime @default(now())
  readCount       Int      @default(1)
  durationSeconds Int?
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ayah            QuranAyah @relation(fields: [ayahId], references: [id], onDelete: Cascade)
  
  @@unique([userId, ayahId])
  @@index([userId])
  @@index([lastReadAt])
}

model QuranUserSettings {
  id                   String   @id @default(cuid())
  userId               Int      @unique
  fontSize             Float    @default(1.0)
  fontFamily           String   @default("uthmani")
  showTajweed          Boolean  @default(false)
  showTranslation      Boolean  @default(true)
  preferredTranslation String?
  defaultReciterId     String?
  audioSpeed           Float    @default(1.0)
  autoPlay             Boolean  @default(false)
  dailyReminder        Boolean  @default(false)
  reminderTime         String?
  theme                String   @default("system")
  language             String   @default("ar")
  
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ==================== Memorization ====================

model QuranMemorizationPlan {
  id              Int   @id @default(autoincrement())
  userId          Int
  name            String
  description     String?
  
  // Settings
  planType        String          @default("daily")
  dailyNewAyahs   Int             @default(5)
  dailyRevision   Int             @default(10)
  revisionMethod  String          @default("spaced")
  
  // Progress
  currentSurahId  Int?
  currentAyah     Int?
  totalMemorized  Int             @default(0)
  
  // State
  state           String          @default("draft")
  
  // Dates
  startDate       DateTime?
  targetDate      DateTime?
  endDate         DateTime?
  
  // Statistics
  streakDays      Int             @default(0)
  longestStreak   Int             @default(0)
  lastActivity    DateTime?
  
  // Relations
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress        QuranMemorizationProgress[]
  revisions       QuranRevisionSchedule[]
  achievements    QuranAchievement[]
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  active          Boolean         @default(true)
  
  @@index([userId])
  @@index([state])
}

model QuranMemorizationProgress {
  id               Int                      @id @default(autoincrement())
  planId           Int
  userId           Int
  ayahId           Int
  surahId          Int
  
  // State
  state            String                   @default("learning")
  
  // Statistics
  revisionCount    Int                      @default(0)
  correctCount     Int                      @default(0)
  mistakeCount     Int                      @default(0)
  
  // Quality rating
  qualityRating    Int?
  
  // Spaced Repetition
  easeFactor       Float                    @default(2.5)
  intervalDays     Int                      @default(1)
  
  // Dates
  firstMemorized   DateTime?
  lastRevised      DateTime?
  nextRevision     DateTime?
  
  // Relations
  plan             QuranMemorizationPlan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  ayah             QuranAyah                @relation(fields: [ayahId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  
  @@unique([planId, ayahId])
  @@index([userId])
  @@index([state])
  @@index([nextRevision])
}

model QuranRevisionSchedule {
  id            Int                    @id @default(autoincrement())
  planId        Int
  userId        Int
  scheduledDate DateTime
  revisionType  String                 @default("daily")
  state         String                 @default("pending")
  
  // Progress
  totalAyahs    Int                    @default(0)
  completedAyahs Int                   @default(0)
  correctAyahs  Int                    @default(0)
  incorrectAyahs Int                   @default(0)
  
  // Time
  startedAt     DateTime?
  completedAt   DateTime?
  
  // Relations
  plan          QuranMemorizationPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  
  @@index([userId])
  @@index([scheduledDate])
  @@index([state])
}

model QuranAchievement {
  id               Int                   @id @default(autoincrement())
  userId           Int
  planId           Int?
  
  achievementType  String
  referenceId      String?
  title            String
  description      String?
  
  // Reward
  points           Int                   @default(0)
  badgeIcon        String?
  badgeColor       String                @default("#FFD700")
  
  // Social
  isShared         Boolean               @default(false)
  sharedAt         DateTime?
  
  // Relations
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan             QuranMemorizationPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  
  achievedAt       DateTime              @default(now())
  
  @@unique([userId, achievementType, referenceId])
  @@index([userId])
  @@index([achievementType])
}

// ==================== Database Management System Models ====================

model AuditLog {
  id            String    @id @default(cuid())
  timestamp     DateTime  @default(now())
  userId        String?
  userName      String?
  userRole      String?
  action        String
  resourceType  String
  resourceName  String
  resourceId    String?
  details       String?
  query         String?
  affectedRows  Int?
  executionTime Float?
  ipAddress     String?
  userAgent     String?
  status        String    @default("success")
  errorMessage  String?

  @@index([timestamp])
  @@index([userId])
  @@index([action])
  @@index([resourceType])
}

model SavedQuery {
  id          String    @id @default(cuid())
  name        String
  description String?
  query       String
  tags        String?
  isFavorite  Boolean   @default(false)
  useCount    Int       @default(0)
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastUsedAt  DateTime?

  @@index([name])
  @@index([isFavorite])
}

model BackupRecord {
  id           String    @id @default(cuid())
  name         String
  type         String    @default("full")
  size         Int       @default(0)
  status       String    @default("pending")
  duration     Int?
  checksum     String?
  location     String?
  errorMessage String?
  metadata     String?
  createdBy    String?
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  @@index([status])
  @@index([createdAt])
}

model QueryHistory {
  id            String   @id @default(cuid())
  query         String
  executionTime Float
  rowCount      Int?
  status        String   @default("success")
  errorMessage  String?
  userId        String?
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

// ==================== Enterprise Stage 1 Models ====================

// 1. SearchIndex - Semantic Search Index
model SearchIndex {
  id                String   @id @default(cuid())
  ayahId            Int      @unique
  content           String
  contentNormalized String?
  embedding         String?
  embeddingModel    String?
  language          String   @default("ar")
  lastIndexed       DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  ayah              QuranAyah @relation(fields: [ayahId], references: [id], onDelete: Cascade)

  @@index([language])
  @@index([lastIndexed])
  @@map("search_indices")
}

// 2. WordAnalysis - Word Morphology Analysis
model WordAnalysis {
  id             Int      @id @default(autoincrement())
  ayahId         Int
  wordPosition   Int
  word           String
  wordNormalized String?
  root           String?
  lemma          String?
  pos            String?
  morphology     String?
  meaning        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ayah           QuranAyah @relation(fields: [ayahId], references: [id], onDelete: Cascade)

  @@unique([ayahId, wordPosition])
  @@index([root])
  @@index([lemma])
  @@index([word])
  @@map("word_analyses")
}

// 3. Notification - User Notifications
model Notification {
  id        String    @id @default(cuid())
  userId    Int
  type      String
  title     String
  message   String
  data      String?
  read      Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([type])
  @@map("notifications")
}

// 4. Analytics - Usage Analytics
model Analytics {
  id         String    @id @default(cuid())
  eventType  String
  userId     Int?
  surahId    Int?
  ayahId     Int?
  reciterId  String?
  sessionId  String?
  ipAddress  String?
  userAgent  String?
  metadata   String?
  timestamp  DateTime  @default(now())
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  ayah       QuranAyah? @relation(fields: [ayahId], references: [id], onDelete: SetNull)

  @@index([eventType])
  @@index([timestamp])
  @@index([userId])
  @@index([surahId])
  @@map("analytics")
}

// 5. UserSession - User Sessions
model UserSession {
  id           String   @id @default(cuid())
  userId       Int
  token        String   @unique
  refreshToken String?  @unique
  deviceInfo   String?
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  lastActivity DateTime @default(now())
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("user_sessions")
}

// 6. TajweedRule - Tajweed Coloring Rules
model TajweedRule {
  id          String   @id @default(cuid())
  nameArabic  String
  nameEnglish String
  code        String   @unique
  description String?
  color       String?
  examples    String?
  category    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
  @@index([category])
  @@map("tajweed_rules")
}

// 7. AudioFile - HLS Audio Files
model AudioFile {
  id              String          @id @default(cuid())
  recitationId    String
  ayahId          Int
  format          String          @default("mp3")
  hlsPlaylistUrl  String?
  hlsSegmentsUrl  String?
  fileSize        Int?
  durationMs      Int?
  bitrate         Int?
  sampleRate      Int?
  channels        Int?            @default(2)
  checksum        String?
  status          String          @default("pending")
  processedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  recitation      QuranRecitation @relation(fields: [recitationId], references: [id], onDelete: Cascade)
  ayah            QuranAyah       @relation(fields: [ayahId], references: [id], onDelete: Cascade)

  @@unique([recitationId, ayahId, format])
  @@index([status])
  @@map("audio_files")
}

// 8. Collection - User Collections
model Collection {
  id              String          @id @default(cuid())
  userId          Int
  name            String
  description     String?
  isPublic        Boolean         @default(false)
  color           String?
  icon            String?
  itemCount       Int             @default(0)
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           CollectionItem[]

  @@index([userId])
  @@index([isPublic])
  @@map("collections")
}

// 9. CollectionItem - Collection Items
model CollectionItem {
  id           String     @id @default(cuid())
  collectionId String
  ayahId       Int
  note         String?
  sortOrder    Int        @default(0)
  addedAt      DateTime   @default(now())
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  ayah         QuranAyah  @relation(fields: [ayahId], references: [id], onDelete: Cascade)

  @@unique([collectionId, ayahId])
  @@index([collectionId])
  @@map("collection_items")
}

// 10. APILog - API Request Logging
model APILog {
  id           String   @id @default(cuid())
  endpoint     String
  method       String
  userId       String?
  ipAddress    String?
  userAgent    String?
  statusCode   Int
  responseTime Int
  requestSize  Int?
  responseSize Int?
  error        String?
  timestamp    DateTime @default(now())

  @@index([endpoint])
  @@index([userId])
  @@index([timestamp])
  @@index([statusCode])
  @@map("api_logs")
}

// 11. FeatureFlag - Feature Toggles
model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  enabled     Boolean  @default(false)
  rollout     Int      @default(100)
  conditions  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@index([enabled])
  @@map("feature_flags")
}

// 12. AppSetting - Application Settings
model AppSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@map("app_settings")
}

// ==================== Image Mushaf Edition Models ====================

model ImageMushafEdition {
  id                  String                @id @default(cuid())
  slug                String                @unique
  nameArabic          String
  nameEnglish         String
  description         String?
  narration           Int                   @default(1)
  version             Int                   @default(1)
  surahsCount         Int                   @default(114)
  quartersCount       Int                   @default(240)
  totalPages          Int                   @default(604)
  width               Int                   @default(1024)
  height              Int                   @default(1656)
  rgbColor            String?
  rgbaBackground      String?
  imageExtension      String                @default(".png")
  dbFilePath          String?
  isDefault           Boolean               @default(false)
  isActive            Boolean               @default(true)
  sourceUrl           String?
  comment             String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  ayahs               ImageMushafAyah[]
  pages               ImageMushafPage[]
  surahs              ImageMushafSurah[]
  discriminators      MushafDiscriminator[]

  @@index([isActive])
  @@index([isDefault])
  @@index([slug])
  @@map("image_mushaf_editions")
}

model ImageMushafAyah {
  id            Int                @id @default(autoincrement())
  editionId     String
  surahId       Int
  quarter       Int
  page          Int
  ayah          Int
  createdAt     DateTime           @default(now())
  edition       ImageMushafEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)
  lines         ImageMushafLine[]
  words         ImageMushafWord[]

  @@unique([editionId, id])
  @@index([surahId])
  @@index([page])
  @@index([editionId])
  @@map("image_mushaf_ayahs")
}

model ImageMushafLine {
  id         Int             @id @default(autoincrement())
  ayahId     Int
  editionId  String
  lineNumber Int
  minX       Int
  maxX       Int
  minY       Int
  maxY       Int
  createdAt  DateTime        @default(now())
  ayah       ImageMushafAyah @relation(fields: [ayahId, editionId], references: [id, editionId], onDelete: Cascade)

  @@unique([editionId, id])
  @@index([ayahId])
  @@map("image_mushaf_lines")
}

model ImageMushafPage {
  id         String            @id @default(cuid())
  editionId  String
  pageNumber Int
  imageUrl   String
  width      Int?
  height     Int?
  createdAt  DateTime          @default(now())
  edition    ImageMushafEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)

  @@unique([editionId, pageNumber])
  @@index([pageNumber])
  @@map("image_mushaf_pages")
}

model ImageMushafSurah {
  id            Int                @id @default(autoincrement())
  editionId     String
  makyaMadanya  Int                @default(0)
  ayatCount     Int
  name          String
  createdAt     DateTime           @default(now())
  edition       ImageMushafEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)

  @@unique([editionId, id])
  @@index([editionId])
  @@map("image_mushaf_surahs")
}

model ImageMushafWord {
  id            Int             @id @default(autoincrement())
  ayahId        Int
  editionId     String
  lineNumber    Int
  wordNumber    Int
  discriminator Int             @default(0)
  minX          Int
  maxX          Int
  minY          Int
  maxY          Int
  createdAt     DateTime        @default(now())
  ayah          ImageMushafAyah @relation(fields: [ayahId, editionId], references: [id, editionId], onDelete: Cascade)

  @@unique([editionId, id])
  @@index([ayahId])
  @@map("image_mushaf_words")
}

model MushafDiscriminator {
  id        Int                @id @default(autoincrement())
  editionId String
  enabled   Boolean            @default(true)
  comment   String?
  createdAt DateTime           @default(now())
  edition   ImageMushafEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)

  @@unique([editionId, id])
  @@index([editionId])
  @@map("mushaf_discriminators")
}

// ==================== TTF Mushaf Edition Models ====================

model TtfMushafEdition {
  id              String             @id @default(cuid())
  slug            String             @unique
  nameArabic      String
  nameEnglish     String
  description     String?
  narration       Int                @default(1)
  version         Int                @default(1)
  surahsCount     Int                @default(114)
  quartersCount   Int                @default(240)
  totalPages      Int                @default(604)
  type            String             @default("uthmani")
  fontExtension   String             @default(".ttf")
  fontFilePath    String?
  dbFilePath      String?
  specialFontUrl  String?
  specialFontName String?
  specialFontSize Int?
  isDefault       Boolean            @default(false)
  isActive        Boolean            @default(true)
  sourceUrl       String?
  comment         String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  discriminators  TtfDiscriminator[]
  ayahs           TtfMushafAyah[]
  pages           TtfMushafPage[]
  surahs          TtfMushafSurah[]

  @@index([isActive])
  @@index([isDefault])
  @@index([slug])
  @@map("ttf_mushaf_editions")
}

model TtfMushafAyah {
  id         Int              @id @default(autoincrement())
  editionId  String
  surahId    Int
  quarter    Int
  page       Int
  ayah       Int
  wordsCount Int              @default(0)
  glyphsCount Int             @default(0)
  createdAt  DateTime         @default(now())
  edition    TtfMushafEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)
  words      TtfMushafWord[]

  @@unique([editionId, id])
  @@index([surahId])
  @@index([page])
  @@index([editionId])
  @@map("ttf_mushaf_ayahs")
}

model TtfMushafPage {
  id         Int              @id @default(autoincrement())
  editionId  String
  pageNumber Int              @default(0)
  fontUrl    String?
  fileName   String?
  fileSize   Int?
  sizeUnit   Int              @default(0)
  isActive   Boolean          @default(true)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  edition    TtfMushafEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)

  @@unique([editionId, pageNumber])
  @@index([editionId])
  @@index([pageNumber])
  @@map("ttf_mushaf_pages")
}

model TtfMushafSurah {
  id           Int              @id @default(autoincrement())
  editionId    String
  makyaMadanya Int              @default(0)
  ayatCount    Int
  name         String
  createdAt    DateTime         @default(now())
  edition      TtfMushafEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)

  @@unique([editionId, id])
  @@index([editionId])
  @@map("ttf_mushaf_surahs")
}

model TtfMushafWord {
  id            Int           @id @default(autoincrement())
  ayahId        Int
  editionId     String
  lineNumber    Int
  wordNumber    Int
  discriminator Int           @default(0)
  text          String
  createdAt     DateTime      @default(now())
  ayah          TtfMushafAyah @relation(fields: [ayahId, editionId], references: [id, editionId], onDelete: Cascade)

  @@unique([editionId, id])
  @@index([ayahId])
  @@map("ttf_mushaf_words")
}

model TtfDiscriminator {
  id        Int              @id @default(autoincrement())
  editionId String
  enabled   Boolean          @default(true)
  comment   String?
  createdAt DateTime         @default(now())
  edition   TtfMushafEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)

  @@unique([editionId, id])
  @@index([editionId])
  @@map("ttf_discriminators")
}
